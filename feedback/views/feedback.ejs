<%- include("partials/header") %>

<h1>Palaute</h1>

<% if (!feedback || feedback.length === 0) { %>
  <p>Ei palautetta</p>
<% } else { %>

  <% feedback.forEach(f => { %>
    <div style="background:white; padding:10px; margin-bottom:10px; border-radius:8px;">

      <p><strong>Asiakas:</strong> <%= f.fullname || f.guest_name %></p>

      <p><strong>Email:</strong> <%= f.guest_email %></p>

      <p><strong>Palaute:</strong> <%= f.feedback %></p>

      <p><strong>Status:</strong> <%= f.handled %></p>

      <p><strong>Päivämäärä:</strong> <%= f.arrived %></p>

    </div>
  <% }) %>

<% } %>

<%- include("partials/footer") %>