<%- include("partials/header") %>

<h2>Tickets</h2>

<table>

  <tr>
    <th>ID</th>
    <th>Customer</th>
    <th>Description</th>
    <th>Status</th>
    <th>Created</th>
    <th>Action</th>
  </tr>

  <% tickets.forEach(ticket => { %>
    <tr>
      <td><%= ticket.id %></td>
      <td><%= ticket.customer %></td>
      <td><%= ticket.description %></td>
      <td><%= ticket.status %></td>
      <td>
        <%= new Date(ticket.arrived).toLocaleDateString("fi-FI") %>
      </td>

      <td>
        <a href="/tickets/view?id=<%= ticket.id %>">Open</a>
      </td>
    </tr>
  <% }) %>

</table>

<%- include("partials/footer") %>